# =============================================================================
# Serenity — Environment Variables
# Copy this file to .env and fill in every value.
# NEVER commit .env to git — add it to .gitignore.
# =============================================================================


# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
APP_NAME=Serenity
APP_ENV=production          # dev | staging | production
SECRET_KEY=your-secret-key-here
DEBUG=false


# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# WARNING: service role key bypasses RLS.
# Never expose it to the frontend or commit it to git.


# ─────────────────────────────────────────────
# OPENAI / LLM
# ─────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Set a hard spend limit in the OpenAI dashboard:
# dashboard.openai.com → Settings → Billing → Usage limits
# Recommended: soft $30/month, hard $50/month


# ─────────────────────────────────────────────
# JOURNAL ENCRYPTION  ← NEW
# Encrypts all journal text before storing in Supabase.
# Generate your key by running this once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back this key up securely — losing it means losing all journal data.
# ─────────────────────────────────────────────
JOURNAL_ENCRYPTION_KEY=your-fernet-key-here


# ─────────────────────────────────────────────
# CORS  ← NEW
# Set to your Flutter web domain in production.
# Comma-separated if you have multiple origins.
# Example: ALLOWED_ORIGINS=https://app.serenity.health
# Dev only: ALLOWED_ORIGINS=*
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-serenity-domain.com


# ─────────────────────────────────────────────
# CHROMADB  ← UPDATED
# Old variables (CHROMA_HOST, CHROMA_PORT) are replaced by these.
# CHROMA_MODE=persistent  → embedded mode, data stored on disk (recommended)
# CHROMA_MODE=server      → separate ChromaDB container
# ─────────────────────────────────────────────
CHROMA_MODE=persistent
CHROMA_PERSIST_PATH=/data/chroma
CHROMA_COLLECTION_JOURNAL=journal_entries

# Only needed if CHROMA_MODE=server:
# CHROMA_SERVER_HOST=chroma
# CHROMA_SERVER_PORT=8000
# CHROMA_AUTH_TOKEN=your-chroma-token-here


# ─────────────────────────────────────────────
# EMAIL (SMTP)  ← UPDATED
# SMTP_USER renamed to SMTP_USERNAME to match new service code.
# Use a Gmail App Password, not your real Gmail password:
# myaccount.google.com → Security → App Passwords
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com      # renamed from SMTP_USER
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Serenity Recovery
EMAIL_FROM_ADDRESS=no-reply@serenity.app


# ─────────────────────────────────────────────
# ADMIN  ← NEW
# Protects POST /admin/inactivity-scan.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Rotate this key every 90 days.
# ─────────────────────────────────────────────
ADMIN_KEY=your-long-random-string-here


# ─────────────────────────────────────────────
# INACTIVITY THRESHOLDS (days)
# ─────────────────────────────────────────────
INACTIVITY_REMINDER_DAYS=1
INACTIVITY_ESCALATION_DAYS=7
