{# ─────────────────────────────────────────────────────────────────────────── #}
{# prompts/email_reminder.j2 — Inactivity reminder email body (HTML)          #}
{# Variables: user_name, days_inactive, streak, app_url                       #}
{# ─────────────────────────────────────────────────────────────────────────── #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Georgia, serif; background: #fafaf8; color: #2d2d2d; margin: 0; padding: 0; }
    .container { max-width: 560px; margin: 40px auto; background: #fff; border-radius: 8px;
                 border: 1px solid #e8e4df; padding: 40px; }
    .header { font-size: 22px; font-weight: bold; color: #3a5a40; margin-bottom: 8px; }
    .subheader { color: #7a7a7a; font-size: 14px; margin-bottom: 32px; }
    .body-text { line-height: 1.8; font-size: 15px; margin-bottom: 24px; }
    .cta { display: inline-block; background: #3a5a40; color: #fff; padding: 14px 28px;
           border-radius: 6px; text-decoration: none; font-size: 15px; }
    .footer { margin-top: 40px; font-size: 12px; color: #aaa; border-top: 1px solid #eee; padding-top: 16px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">We're thinking of you, {{ user_name | default("Friend") }}</div>
    <div class="subheader">Recovery Companion · Check-in Reminder</div>

    <div class="body-text">
      It's been {{ days_inactive }} day{{ "s" if days_inactive != 1 else "" }} since your last journal entry.
      That's okay — life gets full sometimes. But your recovery journey matters, and we're here whenever you're ready.
    </div>

    {% if streak and streak > 0 %}
    <div class="body-text">
      You have a <strong>{{ streak }}-day streak</strong> going. Every entry you write is an act of courage.
      Come back and keep it going.
    </div>
    {% endif %}

    <div class="body-text">
      Take a few minutes today. Write about anything — how you slept, what you're feeling, or even just what you had for breakfast.
      Showing up is what matters.
    </div>

    <a href="{{ app_url }}/journal" class="cta">Write Today's Entry →</a>

    <div class="footer">
      You're receiving this because you opted into check-in reminders.
      <a href="{{ app_url }}/settings/notifications">Manage preferences</a>
    </div>
  </div>
</body>
</html>
