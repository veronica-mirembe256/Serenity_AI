{# ─────────────────────────────────────────────────────────────────────────── #}
{# prompts/email_escalation.j2 — Therapist/rehab escalation email (HTML)      #}
{# Variables: user_name, therapist_name, days_inactive, risk_level, app_url   #}
{# ─────────────────────────────────────────────────────────────────────────── #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Georgia, serif; background: #fafaf8; color: #2d2d2d; margin: 0; padding: 0; }
    .container { max-width: 560px; margin: 40px auto; background: #fff; border-radius: 8px;
                 border: 1px solid #e8e4df; padding: 40px; }
    .header { font-size: 20px; font-weight: bold; color: #8b3a3a; margin-bottom: 8px; }
    .subheader { color: #7a7a7a; font-size: 14px; margin-bottom: 32px; }
    .body-text { line-height: 1.8; font-size: 15px; margin-bottom: 24px; }
    .risk-badge { display: inline-block; background: {% if risk_level == 'high' %}#8b3a3a{% else %}#d97706{% endif %};
                  color: #fff; padding: 4px 12px; border-radius: 4px; font-size: 13px; font-weight: bold; }
    .footer { margin-top: 40px; font-size: 12px; color: #aaa; border-top: 1px solid #eee; padding-top: 16px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">Support Alert — {{ user_name | default("A client") }}</div>
    <div class="subheader">Recovery Companion · Automated Wellness Alert</div>

    <div class="body-text">
      Dear {{ therapist_name | default("Care Provider") }},
    </div>

    <div class="body-text">
      This is an automated alert from Recovery Companion.
      Your client <strong>{{ user_name }}</strong> has not submitted a journal entry in
      <strong>{{ days_inactive }} days</strong> and consented to therapist notification
      should this occur.
    </div>

    <div class="body-text">
      Detected risk level: <span class="risk-badge">{{ risk_level | upper }}</span>
    </div>

    <div class="body-text">
      We recommend reaching out to check in with {{ user_name }} at your earliest convenience.
      This message has been sent in accordance with their documented consent preferences.
    </div>

    <div class="footer">
      This is an automated notification. Do not reply to this email.
      Sent by Recovery Companion in accordance with the user's privacy and consent settings.
    </div>
  </div>
</body>
</html>
